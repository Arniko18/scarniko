{
  "crons": [
    {
      "path": "/api/cron/refresh-token",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    { "source": "/",    "destination": "/landing.html" },
    { "source": "/app", "destination": "/index.html"  }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
